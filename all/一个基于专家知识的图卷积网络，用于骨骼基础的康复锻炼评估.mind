{"root":{"data":{"id":"djuys6019bc0","created":1783694084006,"text":"一个基于专家知识的图卷积网络，用于骨骼基础的康复锻炼评估"},"children":[{"data":{"id":"djuyuagmzkg0","created":1783694250446,"text":"摘要"},"children":[{"data":{"id":"djuyude52bc0","created":1783694256825,"text":"研究背景"},"children":[{"data":{"id":"djuyv2h45i80","created":1783694311425,"text":"自动化评估指导患者进行有效且安全的康复过程中，准确量化患者的训练动作并提供有意义的反馈是一个挑战"},"children":[]}]},{"data":{"id":"djuyuf5u6rk0","created":1783694260677,"text":"研究发现"},"children":[{"data":{"id":"djuyvp6wvrc0","created":1783694360874,"text":"提出了一种基于专家知识的图卷积方法来自动评估物理康复练习的质量"},"children":[]}]}]},{"data":{"id":"djuyuazy2so0","created":1783694251613,"text":"实验方法"},"children":[]},{"data":{"id":"djuyub2q8480","created":1783694251782,"text":"研究结果"},"children":[{"data":{"id":"djuyw2yk0rs0","created":1783694390843,"text":"分支主题"},"children":[]}]},{"data":{"id":"djuyub6raao0","created":1783694252025,"text":"创新点"},"children":[]},{"data":{"id":"djuyubhtwu80","created":1783694252695,"text":"研究方向"},"children":[{"data":{"id":"djuyvvy2is00","created":1783694375577,"text":"提出了一个基于图卷积网络的端到端方法，用于自动评估物理康复练习的质量"},"children":[]}]},{"data":{"id":"djuyubnfk880","created":1783694253033,"text":"结论"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}