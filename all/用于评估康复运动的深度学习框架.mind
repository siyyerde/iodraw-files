{"root":{"data":{"id":"djuxr5sw44o0","created":1783691184101,"text":"用于评估康复运动的深度学习框架"},"children":[{"data":{"id":"djuxt5xffvk0","created":1783691341103,"text":"摘要"},"children":[{"data":{"id":"djuxt7sxze00","created":1783691345186,"text":"研究背景"},"children":[{"data":{"id":"djuxu41f59c0","created":1783691415355,"text":"计算机辅助的物理康复评估对于改善患者预后和降低医疗成本至关重要，但现有方法缺乏通用性、鲁棒性和实际相关性"},"children":[]}]},{"data":{"id":"djuxtdykmt40","created":1783691358587,"text":"研究发现"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}