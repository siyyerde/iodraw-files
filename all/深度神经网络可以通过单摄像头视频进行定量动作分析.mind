{"root":{"data":{"id":"djqn354ppu80","created":1783254850973,"text":"深度神经网络可以通过单摄像头视频进行定量动作分析"},"children":[{"data":{"id":"djqn3dc0trs0","created":1783254868829,"text":"摘要"},"children":[{"data":{"id":"djqn53i0q740","created":1783255004152,"text":"研究背景"},"children":[{"data":{"id":"djqn591ymn40","created":1783255016242,"text":"传统研究方法主要依赖实验室内的光学运动捕捉作为临床运动分析的金标准，但这需要昂贵的设备和高度的训练有素的人员，经济和时间的限制阻碍了这种有价值的高质量数据的常规采集"},"children":[]}]},{"data":{"id":"djqn55qsslc0","created":1783255009037,"text":"研究发现"},"children":[]}]},{"data":{"id":"djqn3dsmw7k0","created":1783254869834,"text":"研究方向"},"children":[]},{"data":{"id":"djqn3dvn5so0","created":1783254870015,"text":"实验方法"},"children":[]},{"data":{"id":"djqn3dxyvzk0","created":1783254870156,"text":"创新点"},"children":[]},{"data":{"id":"djqn3ec14q00","created":1783254871006,"text":"研究结果"},"children":[]},{"data":{"id":"djqn3ehzm7s0","created":1783254871367,"text":"结论"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}