{"root":{"data":{"id":"djqn354ppu80","created":1783254850973,"text":"深度神经网络可以通过单摄像头视频进行定量动作分析"},"children":[{"data":{"id":"djqn3dc0trs0","created":1783254868829,"text":"摘要"},"children":[{"data":{"id":"djqn53i0q740","created":1783255004152,"text":"研究背景","note":"许多神经和肌肉骨骼疾病会损害运动功能，限制了人们的活动能力和社交参与"},"children":[{"data":{"id":"djqn591ymn40","created":1783255016242,"text":"传统研究方法主要依赖实验室内的光学运动捕捉作为临床运动分析的金标准，但这需要昂贵的设备和高度的训练有素的人员，经济和时间的限制阻碍了这种有价值的高质量数据的常规采集"},"children":[]},{"data":{"id":"djqn659ksq00","created":1783255086359,"text":"此外，在实验室收集的运动数据可能无法捕捉到个体在自然环境中如何移动"},"children":[]},{"data":{"id":"djqn604evx40","created":1783255075163,"text":"研究者已利用机器学习模型来估计步态参数或检测疾病存在，但目前的模型通常依赖于专用硬件生成的数据，未能实现低成本和易普及的定量运动分析"},"children":[]}]},{"data":{"id":"djqn55qsslc0","created":1783255009037,"text":"研究发现"},"children":[{"data":{"id":"djqn7enzkgw0","created":1783255185186,"text":"研究团队提出了一种通过普通单摄像头视频预测临床相关运动参数的方法"},"children":[]},{"data":{"id":"djqn8pqbnzc0","created":1783255287636,"text":"其机器学习模型预测的步行速度、步频、最大伸展时的膝关节屈曲角度以及步态偏差指数与真实值的相关性，接近这些指标在患者群体中因自然变异性所限的理论准确性上限"},"children":[]}]}]},{"data":{"id":"djqn3dsmw7k0","created":1783254869834,"text":"研究方向"},"children":[]},{"data":{"id":"djqn3dvn5so0","created":1783254870015,"text":"实验方法"},"children":[{"data":{"id":"djqnch1y4co0","created":1783255582204,"text":"数据集构建"},"children":[{"data":{"id":"djqnd7k0kf40","created":1783255639893,"text":"研究分析了来自吉列儿童专科医疗中心的视频，涉及确诊为脑瘫的独特患者。每个患者同时采集了黄金标准的光学运动捕捉数据，用于生成真实的训练标签"},"children":[]},{"data":{"id":"djqndqgdhso0","created":1783255681032,"text":"视频由放置在距离行走线约3-4米的普通摄像头以1280×960分辨率、29.97帧/秒的帧率录制，随后被下采样至640×480分辨率"},"children":[]}]},{"data":{"id":"djqnchalg200","created":1783255582727,"text":"关键点提取"},"children":[{"data":{"id":"djqndv3c5lk0","created":1783255691128,"text":"使用OpenPose算法从每帧视频中提取25个身体关键点的2D图像平面坐标。研究对其进行了预处理，包括以右髋坐标为中心进行空间归一化、除以右髋与右肩的欧氏距离进行缩放，以及使用一维高斯滤波器进行平滑处理"},"children":[]}]},{"data":{"id":"djqnchfh70g0","created":1783255583023,"text":"手工特征工程","note":"研究设计了两项有助于提升模型性能的衍生时间序列\t"},"children":[{"data":{"id":"djqneb6gqsg0","created":1783255726145,"text":"左右脚踝x坐标（水平图像平面坐标）的差值，用于近似3D脚踝中心距离"},"children":[]},{"data":{"id":"djqneehd4rs0","created":1783255733335,"text":"由脚踝、膝盖和髋部关键点形成的图像平面角度，用于近似真实的膝关节屈曲角"},"children":[]}]},{"data":{"id":"djqnchknuko0","created":1783255583336,"text":"模型架构与训练"},"children":[{"data":{"id":"djqneqkxny00","created":1783255759672,"text":"研究比较了三种模型：卷积神经网络（CNN）、随机森林和岭回归"},"children":[]},{"data":{"id":"djqnf15l5z40","created":1783255782689,"text":"CNN模型是核心方法，其架构由多个1D卷积层、最大池化层、展平层和全连接层组成。每个卷积层包含32个长度为8的滤波器，使用ReLU激活函数和批归一化，后接最大池化层和dropout层"},"children":[]}]},{"data":{"id":"djqnchuj9sg0","created":1783255583933,"text":" 数据增强与窗口切片"},"children":[{"data":{"id":"djqnf77u0iw0","created":1783255795885,"text":"为增加训练样本并提升模型鲁棒性，研究采用了窗口切片方法，从每个500帧的完整视频中提取长度为124帧、间隔31帧的滑动窗口片段，每段视频因此最多产生12个独立的训练片段"},"children":[]}]},{"data":{"id":"djqncsyyds80","created":1783255608145,"text":" 评估方法"},"children":[{"data":{"id":"djqnfb4d4480","created":1783255804382,"text":"对于回归任务，使用预测值与真实值之间的相关系数评估模型拟合优度"},"children":[]},{"data":{"id":"djqnfe1darc0","created":1783255810732,"text":"对于二元分类任务（手术预测），使用ROC曲线下面积（AUC）评估性能"},"children":[]},{"data":{"id":"djqnfhfi5zs0","created":1783255818117,"text":"对于多分类任务（GMFCS评分），使用二次加权Cohen's κ系数。研究将数据集划分为训练集、验证集和测试集，且确保同一患者的所有视频仅出现在其中一个集合中。"},"children":[]}]}]},{"data":{"id":"djqn3dxyvzk0","created":1783254870156,"text":"创新点"},"children":[{"data":{"id":"djqna0out8g0","created":1783255389856,"text":"研究首次证明了可以使用单台普通摄像头拍摄的二维视频来预测临床级别的三维步态指标"},"children":[]},{"data":{"id":"djqnaf9j8lk0","created":1783255421581,"text":"利用深度神经网络直接处理由OpenPose提取的二维关键点轨迹时间序列，无需大量手工特征工程，就能从噪声较大的信号中提取出临床相关的运动参数"},"children":[]},{"data":{"id":"djqnbn4fe9k0","created":1783255517051,"text":"在预测综合临床评估指标（如GMFCS评分）以及预测未来手术决策（如SEMLS）方面有很大潜力"},"children":[]}]},{"data":{"id":"djqn3ec14q00","created":1783254871006,"text":"研究结果"},"children":[{"data":{"id":"djqngcnyjk00","created":1783255886108,"text":"常用步态指标的预测性能"},"children":[{"data":{"id":"djqngtcm8h40","created":1783255922428,"text":"研究团队使用卷积神经网络模型，从15秒的矢状面步行视频中预测了步态指标。预测的步行速度、步频和膝关节最大伸展时屈曲角度与真实值（来自光学运动捕捉）的相关系数分别达到了0.73、0.79和0.83"},"children":[]}]},{"data":{"id":"djqngeoae5c0","created":1783255890482,"text":"综合临床指标的预测性能"},"children":[{"data":{"id":"djqnh0oidso0","created":1783255938384,"text":"步态偏差指数（GDI）的预测相关系数为0.75，这一数值与该指标在同患者不同访视间的组内相关系数相当"},"children":[]},{"data":{"id":"djqnhb018000","created":1783255960849,"text":"对于粗大运动功能分级系统得分，预测的加权kappa系数为0.71，模型预测的正确率为66%，且所有错误分类均不超过1个等级"},"children":[]}]},{"data":{"id":"djqnggi4vog0","created":1783255894463,"text":"预测准确性的理论上限分析"},"children":[{"data":{"id":"djqnhhpdrqo0","created":1783255975442,"text":"对于步行速度，研究指出其模型解释了53%的观察方差。理论上模型可解释的方差上限为75%"},"children":[]}]},{"data":{"id":"djqngidl6yg0","created":1783255898542,"text":"非矢状面信息的影响"},"children":[{"data":{"id":"djqni5157g00","created":1783256026219,"text":"矢状面视频未能完全捕捉到计算GDI所需的额状面和横断面运动信息"},"children":[]}]},{"data":{"id":"djqngk65gtc0","created":1783255902446,"text":" 纵向变化和不对称性分析"},"children":[{"data":{"id":"djqnie8g9r40","created":1783256046252,"text":"模型部分捕捉了患者的步态不对称性和纵向变化"},"children":[]}]},{"data":{"id":"djqngmnz3340","created":1783255907877,"text":"手术决策预测"},"children":[{"data":{"id":"djqnipljya80","created":1783256070989,"text":"模型在预测患者是否将接受单次多平面手术方面，其ROC曲线下面积为0.71。将CNN模型与基于GDI的逻辑回归模型进行集成后，预测AUC提升至0.73"},"children":[]}]}]},{"data":{"id":"djqn3ehzm7s0","created":1783254871367,"text":"结论"},"children":[{"data":{"id":"djqnjfk52v40","created":1783256127500,"text":"展望"},"children":[{"data":{"id":"djqnjn7gmxc0","created":1783256144148,"text":"同样的方法可以应用于任何患者群体和任何步态指标"},"children":[]},{"data":{"id":"djqnk3oyuhs0","created":1783256180035,"text":"低成本且便捷的测量方式能够辅助和改善临床实践，使医生能够远程跟踪康复或术后结果，并使研究人员能够进行流行病学规模的临床研究"},"children":[]},{"data":{"id":"djqnkdrvrp40","created":1783256201979,"text":"将视频预测的CNN模型与基于运动捕捉GDI的逻辑回归模型集成后，手术决策预测的AUC值从0.71提升到了0.73，显示出结合不同信号源可以改进预测性能"},"children":[]}]},{"data":{"id":"djqnjhjvr680","created":1783256131838,"text":"缺陷"},"children":[{"data":{"id":"djqnlnh7yg80","created":1783256301466,"text":"为使用当前模型评估脑瘫儿童的相同步态参数，必须严格遵守临床协议，包括类似的相机角度和受试者着装；对于更宽松的采集协议，应使用非专业用户录制的新视频进行方法测试"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}