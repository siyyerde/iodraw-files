{"root":{"data":{"id":"djqnpl4dehs0","created":1783256609792,"text":"基于视频的可解释且细粒度的帕金森病手指敲击测试运动特征量化"},"children":[{"data":{"id":"djqnppouyk00","created":1783256619738,"text":"摘要"},"children":[{"data":{"id":"djqnpsed1vc0","created":1783256625634,"text":"研究背景","note":"临床上，手指敲击测试是一项标准的运动评估，但医生是通过目视评估患者的敲击表现并给出一个总体严重程度评分"},"children":[{"data":{"id":"djqnr17yocg0","created":1783256723202,"text":" "},"children":[]}]},{"data":{"id":"djqnpv1ld600","created":1783256631392,"text":"研究发现"},"children":[]}]},{"data":{"id":"djqnppyixn40","created":1783256620323,"text":"实验方法"},"children":[]},{"data":{"id":"djqnpq0xf5c0","created":1783256620468,"text":"研究方向"},"children":[]},{"data":{"id":"djqnpq3pxgg0","created":1783256620637,"text":"创新点"},"children":[]},{"data":{"id":"djqnpqgcoeg0","created":1783256621401,"text":"研究结果"},"children":[]},{"data":{"id":"djqnpqjn3n40","created":1783256621600,"text":"结论"},"children":[{"data":{"id":"djqnq5ip0y80","created":1783256654194,"text":"缺陷"},"children":[]},{"data":{"id":"djqnq68xoig0","created":1783256655781,"text":"展望"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}