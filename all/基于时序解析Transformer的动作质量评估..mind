{"root":{"data":{"id":"dk3fr7eotcw0","created":1784554447227,"text":"基于时序解析Transformer的动作质量评估"},"children":[{"data":{"id":"dk3ftri1ia00","created":1784554647694,"text":"摘要"},"children":[{"data":{"id":"dk3gh4g4noo0","created":1784556478252,"text":"研究背景"},"children":[{"data":{"id":"dk3gh83v0x40","created":1784556486217,"text":"动作质量评估需要精细化的时空推理来感知细微的动作差异，其核心挑战在于如何建模动作视频中的细粒度子动作以及它们之间的依赖关系"},"children":[]}]},{"data":{"id":"dk3gh6c4jl40","created":1784556482363,"text":"研究发现"},"children":[{"data":{"id":"dk3ghbslxoo0","created":1784556494244,"text":"本文提出了一个名为FineDiving的细粒度数据集，并开发了一个过程感知的时序动作质量评估模型"},"children":[]}]}]},{"data":{"id":"dk3fu6oedk80","created":1784554680730,"text":"研究方向"},"children":[{"data":{"id":"dk3ghety4zk0","created":1784556500855,"text":"分支主题"},"children":[]}]},{"data":{"id":"dk3fubgm9q80","created":1784554691144,"text":"实验结果"},"children":[]},{"data":{"id":"dk3fuqd0wqo0","created":1784554723578,"text":"创新点"},"children":[]},{"data":{"id":"dk3fv1gs7hc0","created":1784554747750,"text":"实验方法"},"children":[]},{"data":{"id":"dk3fv5el7s80","created":1784554756324,"text":"展望"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}